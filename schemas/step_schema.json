{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrchestrAI Workflow Step",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique step identifier used by ExecutionLayer registry"
    },
    "role": {
      "type": "string",
      "description": "Logical role responsible for the step (scriptwriter, media, strategist...)"
    },
    "input": {
      "type": ["object", "null"],
      "description": "Optional input mapping from ExecutionContext"
    },
    "config": {
      "type": ["object", "null"],
      "description": "Optional execution configuration"
    },
    "constraints": {
      "type": ["object", "null"],
      "description": "Execution limits (tokens, time, safety rules...)"
    },
    "meta": {
      "type": ["object", "null"],
      "description": "Non-functional metadata (debug, trace, analytics...)"
    }
  }
}